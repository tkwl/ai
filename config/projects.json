{
  "$schema": "Project configuration for Vance Kessler - Express AI deployment",

  "projects": {
    "express-ai": {
      "name": "Express AI",
      "description": "Express AI operations - autonomous AI employee platform",
      "working_directory": "/home/ubuntu/ai",
      "auto_merge": false,
      "telegram": {
        "groups": ["Express AI"],
        "respond_to_unaddressed": true,
        "respond_to_dms": true
      },
      "github": {
        "org": "tkwl",
        "repo": "ai"
      },
      "context": {
        "tech_stack": ["Python", "Claude Agent SDK", "Telethon", "Claude API", "Asana API", "Slack API", "Gmail API"],
        "description": "Express AI employee operations: task execution, process automation, client work, communications"
      },
      "integrations": {
        "asana": true,
        "slack": true,
        "gmail": true,
        "calendar": true
      }
    }
  },

  "defaults": {
    "working_directory": "/home/ubuntu",
    "telegram": {
      "respond_to_all": true,
      "respond_to_mentions": true,
      "respond_to_dms": true,
      "mention_triggers": ["@vance", "vance", "hey vance", "Vance"]
    },
    "response": {
      "typing_indicator": true,
      "max_response_length": 4000,
      "timeout_seconds": 300
    }
  }
}
